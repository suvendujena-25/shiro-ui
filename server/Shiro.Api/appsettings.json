{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "ShiroDb": "Data Source=shiro-history.db"
  },
  "AI": {
    "Provider": "Ollama"
  },
  "OpenAI": {
    "BaseUrl": "https://api.openai.com",
    "Model": "gpt-4.1-mini"
  },
  "Ollama": {
    "BaseUrl": "http://localhost:11434",
    "Model": "llama3.2:3b",
    "MaxTokens": 650,
    "KeepAlive": "15m"
  },
  "AllowedHosts": "*"
}
